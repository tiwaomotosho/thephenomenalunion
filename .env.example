# Copy this file to ".env" and fill in real values. Vite only exposes
# variables prefixed with VITE_ to the browser. Restart the dev server after
# editing. Never commit your real .env (it is gitignored).

# Paystack public key. While this is empty the Blessings page runs in DEMO mode
# (simulated checkout, no real charge). Set it to go live.
#   pk_test_xxxx while testing, pk_live_xxxx in production.
VITE_PAYSTACK_PUBLIC_KEY=

# Google Apps Script web app URL for the Notes wall backend (see
# docs/integrations.md). While empty the Notes wall uses local browser storage.
VITE_NOTES_ENDPOINT=
