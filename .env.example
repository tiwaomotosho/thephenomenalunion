# Copy this file to ".env" and fill in real values. Vite only exposes
# variables prefixed with VITE_ to the browser. Restart the dev server after
# editing. Never commit your real .env (it is gitignored).

# Google Apps Script web app URL that emails a receipt when a guest confirms a
# bank-transfer blessing (see docs/integrations.md). While empty, the Blessings
# page still works end to end (placeholder mode) but sends no receipt email.
# Edit the account details themselves in src/content/payments.json.
VITE_RECEIPT_ENDPOINT=

# Google Apps Script web app URL for the Notes wall backend (see
# docs/integrations.md). While empty the Notes wall uses local browser storage.
VITE_NOTES_ENDPOINT=
